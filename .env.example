# CodeIgniter environment
CI_ENVIRONMENT = development

# Base URL (Docker)
app.baseURL = 'http://localhost:8080/'

# Database (Docker MySQL)
database.default.hostname = db
database.default.database = checkiso
database.default.username = checkiso
database.default.password = checkiso
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

# Security
app.CSPEnabled = true

# Sessions
session.driver = 'CodeIgniter\Session\Handlers\DatabaseHandler'
session.cookieSecure = false
session.cookieSameSite = 'Lax'

# Encryption key (generate per env)
# app.encryption.key =
